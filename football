<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global Football Elite - Premium Soccer Equipment</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lucide/0.263.0/lucide.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .hero-gradient { background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1574629810360-7efbbe195018?auto=format&fit=crop&q=80&w=1920'); background-size: cover; background-position: center; }
    </style>
</head>
<body class="bg-gray-50 text-gray-900">

    <!-- 导航栏 -->
    <nav class="fixed w-full z-50 bg-white/90 backdrop-blur-md border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-20 items-center">
                <div class="flex items-center space-x-2">
                    <i data-lucide="trophy" class="w-8 h-8 text-blue-600"></i>
                    <span class="text-2xl font-bold tracking-tight text-gray-900 uppercase">GFE <span class="text-blue-600">Sports</span></span>
                </div>
                
                <!-- 桌面端菜单 -->
                <div class="hidden md:flex space-x-8 font-medium">
                    <a href="#home" class="hover:text-blue-600 transition">首页</a>
                    <a href="#products" class="hover:text-blue-600 transition">成品足球</a>
                    <a href="#custom" class="hover:text-blue-600 transition">定制服务</a>
                    <a href="#about" class="hover:text-blue-600 transition">关于我们</a>
                    <a href="#contact" class="hover:text-blue-600 transition">联系我们</a>
                </div>

                <div class="flex items-center space-x-4">
                    <button class="bg-blue-600 text-white px-5 py-2 rounded-full font-semibold hover:bg-blue-700 transition shadow-lg shadow-blue-200">
                        获取报价
                    </button>
                    <!-- 移动端菜单按钮 -->
                    <button class="md:hidden" onclick="toggleMenu()">
                        <i data-lucide="menu" class="w-6 h-6"></i>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- 移动端侧边栏 (默认隐藏) -->
    <div id="mobile-menu" class="fixed inset-0 z-[60] bg-white transform translate-x-full transition-transform duration-300 md:hidden">
        <div class="p-6">
            <div class="flex justify-end">
                <button onclick="toggleMenu()"><i data-lucide="x" class="w-8 h-8"></i></button>
            </div>
            <div class="flex flex-col space-y-6 mt-10 text-xl font-semibold">
                <a href="#home" onclick="toggleMenu()">首页</a>
                <a href="#products" onclick="toggleMenu()">成品足球</a>
                <a href="#custom" onclick="toggleMenu()">定制服务</a>
                <a href="#contact" onclick="toggleMenu()">联系我们</a>
            </div>
        </div>
    </div>

    <!-- 英雄展示区 -->
    <section id="home" class="hero-gradient h-screen flex items-center justify-center text-center text-white pt-20">
        <div class="max-w-4xl px-4">
            <h1 class="text-5xl md:text-7xl font-bold mb-6 leading-tight">顶级赛事级足球<br>全球批发供应</h1>
            <p class="text-lg md:text-xl mb-10 text-gray-200">我们为职业联赛、俱乐部及全球零售商提供高品质成品足球。符合 FIFA 标准，支持全球发货。</p>
            <div class="flex flex-col sm:flex-row justify-center gap-4">
                <a href="#products" class="bg-white text-gray-900 px-8 py-4 rounded-full font-bold text-lg hover:bg-blue-50 transition">浏览产品</a>
                <a href="#contact" class="border-2 border-white text-white px-8 py-4 rounded-full font-bold text-lg hover:bg-white/10 transition">在线咨询</a>
            </div>
        </div>
    </section>

    <!-- 特色功能区 -->
    <section class="py-16 bg-white">
        <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="flex items-start space-x-4 p-6 rounded-2xl bg-gray-50">
                <div class="bg-blue-100 p-3 rounded-lg text-blue-600"><i data-lucide="shield-check"></i></div>
                <div>
                    <h3 class="font-bold text-lg mb-2">质量保证</h3>
                    <p class="text-gray-600 text-sm">所有足球均经过严格的压力、圆度和吸水率测试。</p>
                </div>
            </div>
            <div class="flex items-start space-x-4 p-6 rounded-2xl bg-gray-50">
                <div class="bg-green-100 p-3 rounded-lg text-green-600"><i data-lucide="truck"></i></div>
                <div>
                    <h3 class="font-bold text-lg mb-2">快速物流</h3>
                    <p class="text-gray-600 text-sm">与DHL、FedEx深度合作，确保全球货物准时到达。</p>
                </div>
            </div>
            <div class="flex items-start space-x-4 p-6 rounded-2xl bg-gray-50">
                <div class="bg-purple-100 p-3 rounded-lg text-purple-600"><i data-lucide="settings-2"></i></div>
                <div>
                    <h3 class="font-bold text-lg mb-2">OEM 定制</h3>
                    <p class="text-gray-600 text-sm">支持批量Logo印制及包装定制，打造您的专属品牌。</p>
                </div>
            </div>
        </div>
    </section>

    <!-- 产品分类展示 -->
    <section id="products" class="py-20 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4">
            <div class="text-center mb-16">
                <h2 class="text-4xl font-bold mb-4">热门产品系列</h2>
                <p class="text-gray-600">从职业训练到顶级赛事，满足您不同等级的需求</p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
                <!-- 产品 1 -->
                <div class="group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all border border-gray-100">
                    <div class="relative overflow-hidden aspect-square">
                        <img src="https://images.unsplash.com/photo-1543351611-58f69d7c1781?auto=format&fit=crop&q=80&w=800" alt="专业比赛足球" class="object-cover w-full h-full group-hover:scale-110 transition duration-500">
                        <span class="absolute top-4 left-4 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full uppercase">热销</span>
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-2">Elite Pro Match Ball</h3>
                        <p class="text-gray-500 text-sm mb-4">热粘合工艺，5号标准赛用球，卓越的飞行稳定性。</p>
                        <div class="flex justify-between items-center">
                            <span class="text-blue-600 font-bold text-lg">$18.50 - $25.00</span>
                            <span class="text-gray-400 text-xs">起订量: 500 pcs</span>
                        </div>
                    </div>
                </div>

                <!-- 产品 2 -->
                <div class="group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all border border-gray-100">
                    <div class="relative overflow-hidden aspect-square">
                        <img src="https://images.unsplash.com/photo-1560272564-c83b66b1ad12?auto=format&fit=crop&q=80&w=800" alt="训练足球" class="object-cover w-full h-full group-hover:scale-110 transition duration-500">
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-2">Club Training Series</h3>
                        <p class="text-gray-500 text-sm mb-4">高品质PU材质，耐磨性强，适合高强度训练使用。</p>
                        <div class="flex justify-between items-center">
                            <span class="text-blue-600 font-bold text-lg">$8.00 - $12.00</span>
                            <span class="text-gray-400 text-xs">起订量: 1000 pcs</span>
                        </div>
                    </div>
                </div>

                <!-- 产品 3 -->
                <div class="group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all border border-gray-100">
                    <div class="relative overflow-hidden aspect-square">
                        <img src="https://images.unsplash.com/photo-1614632537190-23e414d40959?auto=format&fit=crop&q=80&w=800" alt="室内足球" class="object-cover w-full h-full group-hover:scale-110 transition duration-500">
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-2">Indoor Futsal Specialist</h3>
                        <p class="text-gray-500 text-sm mb-4">低弹力设计，专为室内五人制赛场研发。</p>
                        <div class="flex justify-between items-center">
                            <span class="text-blue-600 font-bold text-lg">$12.50 - $16.00</span>
                            <span class="text-gray-400 text-xs">起订量: 500 pcs</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 优势展示 (带统计) -->
    <section class="py-20 bg-blue-900 text-white">
        <div class="max-w-7xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
            <div>
                <div class="text-4xl font-bold mb-2">15+</div>
                <div class="text-blue-200">年行业经验</div>
            </div>
            <div>
                <div class="text-4xl font-bold mb-2">50+</div>
                <div class="text-blue-200">出口国家</div>
            </div>
            <div>
                <div class="text-4xl font-bold mb-2">1M+</div>
                <div class="text-blue-200">年产量</div>
            </div>
            <div>
                <div class="text-4xl font-bold mb-2">24h</div>
                <div class="text-blue-200">响应时间</div>
            </div>
        </div>
    </section>

    <!-- 联系我们表单 -->
    <section id="contact" class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4">
            <div class="flex flex-col lg:flex-row gap-16">
                <div class="lg:w-1/2">
                    <h2 class="text-4xl font-bold mb-6">开启您的全球采购</h2>
                    <p class="text-gray-600 mb-8 leading-relaxed">
                        无论您是寻找长期供应商还是单次批量采购，我们的专家团队都将为您提供最具竞争力的报价和物流方案。填写表单，我们将在 12 小时内给您答复。
                    </p>
                    <div class="space-y-4 text-gray-700">
                        <div class="flex items-center space-x-4">
                            <i data-lucide="mail" class="text-blue-600"></i>
                            <span>sales@gfe-sports.com</span>
                        </div>
                        <div class="flex items-center space-x-4">
                            <i data-lucide="phone" class="text-blue-600"></i>
                            <span>+86 123-4567-8910</span>
                        </div>
                        <div class="flex items-center space-x-4">
                            <i data-lucide="map-pin" class="text-blue-600"></i>
                            <span>中国·浙江省·义乌市体育用品产业园</span>
                        </div>
                    </div>
                </div>
                
                <div class="lg:w-1/2 bg-gray-50 p-8 rounded-3xl border border-gray-100 shadow-sm">
                    <form onsubmit="event.preventDefault(); alert('询价已发送！我们会尽快联系您。');" class="space-y-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <input type="text" placeholder="您的姓名" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-500 outline-none">
                            <input type="email" placeholder="公司邮箱" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <input type="text" placeholder="产品需求与数量" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-500 outline-none">
                        <textarea placeholder="留言内容..." rows="4" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-500 outline-none"></textarea>
                        <button type="submit" class="w-full bg-blue-600 text-white font-bold py-4 rounded-xl hover:bg-blue-700 transition shadow-lg shadow-blue-200">
                            立即获取详细报价
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <!-- 页脚 -->
    <footer class="bg-gray-900 text-gray-400 py-12 border-t border-gray-800">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <div class="flex justify-center items-center space-x-2 mb-8">
                <i data-lucide="trophy" class="w-6 h-6 text-blue-500"></i>
                <span class="text-xl font-bold text-white uppercase tracking-wider">GFE <span class="text-blue-500">Sports</span></span>
            </div>
            <p class="mb-8">专注高品质足球制造与出口。Professional Soccer Ball Manufacturer & Exporter Since 2008.</p>
            <div class="flex justify-center space-x-6 mb-8">
                <a href="#" class="hover:text-white"><i data-lucide="facebook"></i></a>
                <a href="#" class="hover:text-white"><i data-lucide="twitter"></i></a>
                <a href="#" class="hover:text-white"><i data-lucide="instagram"></i></a>
                <a href="#" class="hover:text-white"><i data-lucide="linkedin"></i></a>
            </div>
            <div class="text-sm pt-8 border-t border-gray-800">
                &copy; 2024 GFE Sports International. All Rights Reserved.
            </div>
        </div>
    </footer>

    <script>
        // 初始化 Lucide 图标
        lucide.createIcons();

        // 移动端菜单切换
        function toggleMenu() {
            const menu = document.getElementById('mobile-menu');
            if (menu.classList.contains('translate-x-full')) {
                menu.classList.remove('translate-x-full');
            } else {
                menu.classList.add('translate-x-full');
            }
        }

        // 导航栏滚动效果
        window.addEventListener('scroll', function() {
            const nav = document.querySelector('nav');
            if (window.scrollY > 50) {
                nav.classList.add('shadow-md');
            } else {
                nav.classList.remove('shadow-md');
            }
        });
    </script>
</body>
</html>
